.venv/
__pycache__/
*.pyc

# Models: keep the per-board-size "latest.pt" snapshots in git (so a trained
# result can be committed) but ignore everything else under models/ (rotating
# checkpoint_*.pt binaries would otherwise bloat the repo).
models/**
!models/**/
!models/latest.pt
!models/**/latest.pt

checkpoints/
sgf/
*.h5
*.ckpt
data/
*.npz
logs/

# train_state*.json (cumulative episode counters) are tracked so "how many
# episodes trained" is recorded alongside the committed model.
